# Copy this file to .env and fill in your values.

# Base URL for the REST API.
# Leave empty (or unset) to use the Vite dev-server proxy (development only).
# In production set this to the full backend URL, e.g. https://api.example.com
VITE_API_URL=

# Base URL for WebSocket connections.
# Leave empty (or unset) to use the Vite dev-server proxy (development only).
# In production set this to the WebSocket backend URL, e.g. wss://api.example.com
VITE_WS_URL=
