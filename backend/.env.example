# Copy this file to .env and fill in your values.
#
# PostgreSQL connection URL (required).
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/omnichannel

# Connection-pool tuning (optional – defaults shown)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Set to "true" to log every SQL statement to the console (dev only)
DB_ECHO=false

# CORS allowed origins.
# Use "*" to allow all origins (development) or a comma-separated list of URLs
# for production, e.g. "http://localhost:3000,https://app.example.com"
CORS_ORIGINS=*
